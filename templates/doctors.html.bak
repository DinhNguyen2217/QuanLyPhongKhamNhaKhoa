{% include 'index.html' %} <style>
    /* Ẩn các phần không liên quan của trang index khi ở trang bác sĩ */
    .main-container, .price-section { display: none; } 
    
    .doctors-page-container {
        padding: 60px 10%;
        background-color: #f6fbfd;
        min-height: 800px;
    }
    .doctor-card {
        background: white;
        display: flex;
        margin-bottom: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        border-radius: 8px;
        overflow: hidden;
    }
    .doctor-info { padding: 30px; }
    .doctor-name { color: #0046a7; font-size: 24px; margin-bottom: 10px; text-transform: uppercase; }
</style>

